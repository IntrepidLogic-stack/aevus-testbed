.venv/
__pycache__/
*.pyc
# Python build/packaging artifacts — regenerated by `pip install -e .` on every
# host (CI, local, the EC2 box), so they must not be tracked.
*.egg-info/
*.egg
build/
dist/
.eggs/
.env
*.db
*.sqlite
forecast_cache.json
weather_cache.json
*.pem
*.bak
*.log
node_modules/
dashboard/api-client.src.js
dashboard/api-client.src.js.patch
dashboard-staging/api-client.src.js
dashboard-staging/src/
*.bak.*

# Greengrass component artifacts — generated by deploy/greengrass/package-artifacts.sh
deploy/greengrass/artifacts/

# Terraform — local state, provider cache, plan files. Real state lives in
# the S3 backend; these are dev-side artifacts that must never be committed
# (state files contain secrets; the provider binary alone is 600+ MB and
# the pre-receive hook rejects pushes containing it).
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tf.plan
.terraform.lock.hcl

# Reference datasets (real downloads — not committed; license + size)
reference_data/raw/
reference_data/prepped/

# OPC UA client certs/keys (P3) — generated at runtime, never commit
certs/
