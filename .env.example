# Aevus Testbed — Environment Configuration
# Copy to .env and fill in actual values. Never commit .env.

# ── Lab Network (Flat Interim — 192.168.88.0/24) ──
LAB_SUBNET=192.168.88.0/24
MIKROTIK_IP=192.168.88.1
CATALYST_IP=192.168.88.2
UPLOGIX_IP=192.168.88.5
TRIO_RADIO_1_IP=192.168.88.11
TRIO_RADIO_2_IP=192.168.88.12
SCADAPACK_IP=192.168.88.21
EDGE_COLLECTOR_IP=192.168.88.252
SNMP_COMMUNITY=aevus_ro
SNMP_VERSION=2c

# ── Target Network (VLANed — post site-visit migration) ──
# VLAN10_MGMT=10.50.10.0/24
# VLAN20_OT=10.50.20.0/24
# VLAN30_AEVUS=10.50.30.0/24

# ── SCADAPack 470 Protocols ──
MODBUS_PORT=502
MODBUS_SLAVE_ID=1
DNP3_PORT=20000
DNP3_OUTSTATION_ADDR=10
DNP3_MASTER_ADDR=1

# ── InfluxDB ──
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influx-token-here
INFLUX_ORG=intrepid-logic
INFLUX_BUCKET=aevus_telemetry
INFLUX_RETENTION=90d

# ── SQLite (asset registry, alerts, config) ──
SQLITE_PATH=./data/aevus.db

# ── FastAPI Server ──
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=*

# ── Polling Intervals (seconds) ──
POLL_INTERVAL_RADIO=30
POLL_INTERVAL_RTU=5
POLL_INTERVAL_SWITCH=30
POLL_INTERVAL_ROUTER=30

# ── Alert Thresholds — Radio (Trio JR900) ──
THRESHOLD_HEALTH_WARN=80
THRESHOLD_HEALTH_CRIT=50
THRESHOLD_RSSI_WARN=-80
THRESHOLD_RSSI_CRIT=-90
THRESHOLD_SNR_WARN=15
THRESHOLD_SNR_CRIT=10
THRESHOLD_RADIO_TEMP_WARN=60
THRESHOLD_RADIO_TEMP_CRIT=75
THRESHOLD_ERROR_RATE_WARN=1
THRESHOLD_ERROR_RATE_CRIT=5

# ── Alert Thresholds — RTU (SCADAPack 470) ──
THRESHOLD_BATTERY_WARN=12.0
THRESHOLD_BATTERY_CRIT=11.5
THRESHOLD_SUCTION_WARN=800
THRESHOLD_SUCTION_CRIT=900
THRESHOLD_DISCHARGE_WARN=1200
THRESHOLD_DISCHARGE_CRIT=1400
THRESHOLD_VIBRATION_WARN=4.5
THRESHOLD_VIBRATION_CRIT=7.1

# ── Alert Thresholds — Network ──
THRESHOLD_CPU_WARN=70
THRESHOLD_CPU_CRIT=90
THRESHOLD_IF_ERRORS_WARN=100
THRESHOLD_IF_ERRORS_CRIT=1000

# ── Mapbox (if geographic view needed later) ──
MAPBOX_TOKEN=pk.eyJ1Ijoid29vZHlpbCIsImEiOiJjbWR4eW5keTUwOTlvMmxxMXo1aGljdWdyIn0.f4ud1cQ6mf-oNM69iY6fEg

