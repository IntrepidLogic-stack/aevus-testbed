# ALTERNATE DEPLOY PATTERN — uses SSM instead of SSH
# To migrate from SSH-key-based deploy to SSM:
#  1. Rename current ci-cd.yml → ci-cd.ssh.yml.bak (preserve)
#  2. Rename this file → ci-cd.yml
#  3. Delete the EC2_SSH_KEY + EC2_USER + EC2_HOST GitHub secrets
#     (gh secret delete EC2_SSH_KEY --repo IntrepidLogic-stack/aevus-testbed)
#  4. Test by pushing a no-op change
#
# Benefits over SSH:
#  - No SSH key stored in GitHub Actions secrets (eliminates exfil risk)
#  - All commands logged in CloudTrail (audit trail for every deploy)
#  - No SSH port exposure needed (security group can drop SSH inbound)
#  - Key rotation = role policy update (not file replacement)

name: CI/CD

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  id-token: write
  contents: read

jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Lint
        run: |
          pip install ruff
          ruff check . --select E,F,I --ignore E501
      - name: Syntax check
        run: find . -name "*.py" -not -path "./.venv/*" -exec python -m py_compile {} +

  deploy:
    needs: ci
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
    runs-on: ubuntu-latest
    environment: production
    steps:
      - name: Configure AWS credentials (OIDC — no stored keys)
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::676433090238:role/il-github-actions-deploy
          aws-region: us-east-1

      - name: Deploy via SSM (no SSH key needed)
        run: |
          CMD_ID=$(aws ssm send-command \
            --instance-ids i-017562fca3e3401a8 \
            --document-name AWS-RunShellScript \
            --parameters 'commands=["sudo -u ubuntu bash /home/ubuntu/aevus-testbed/deploy.sh"]' \
            --comment "Deploy from commit $GITHUB_SHA by $GITHUB_ACTOR" \
            --query 'Command.CommandId' --output text)
          echo "SSM command: $CMD_ID"
          # Wait for completion
          aws ssm wait command-executed \
            --command-id "$CMD_ID" \
            --instance-id i-017562fca3e3401a8 \
          || (aws ssm get-command-invocation --command-id "$CMD_ID" --instance-id i-017562fca3e3401a8 --query 'StandardErrorContent' --output text && exit 1)
          # Show deploy log
          aws ssm get-command-invocation --command-id "$CMD_ID" --instance-id i-017562fca3e3401a8 --query 'StandardOutputContent' --output text
