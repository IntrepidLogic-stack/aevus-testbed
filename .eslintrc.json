{
  "env": {
    "browser": true,
    "es6": true
  },
  "globals": {
    "Chart": "readonly",
    "L": "readonly",
    "maplibregl": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": "off",
    "no-redeclare": "warn",
    "no-constant-condition": "warn",
    "no-unreachable": "warn",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-empty": "warn",
    "no-extra-semi": "warn",
    "no-func-assign": "error",
    "no-irregular-whitespace": "warn",
    "use-isnan": "error",
    "valid-typeof": "error"
  }
}
